// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  DELAYED
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id           String     @id @default(cuid())
  fullName     String
  email        String     @unique
  passwordHash String
  role         Role       @default(TEAM_MEMBER)
  tasks        Task[]
  documents    Document[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id          String           @id @default(cuid())
  name        String
  description String?
  ownerId     String?
  status      ProjectStatus    @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  processes   ProjectProcess[]
  tasks       Task[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Process {
  id                String           @id @default(cuid())
  name              String
  description       String?
  responsiblePerson String
  inputs            String[]
  outputs           String[]
  indicators        Json
  projects          ProjectProcess[]
  tasks             Task[]
  documents         Document[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model ProjectProcess {
  projectId String
  processId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@id([projectId, processId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  projectId   String
  processId   String
  assigneeId  String?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  process     Process    @relation(fields: [processId], references: [id], onDelete: Cascade)
  assignee    User?      @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Document {
  id           String   @id @default(cuid())
  name         String
  mimeType     String
  size         Int
  path         String
  processId    String?
  taskId       String?
  uploadedById String
  process      Process? @relation(fields: [processId], references: [id], onDelete: SetNull)
  task         Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([processId])
  @@index([taskId])
}
