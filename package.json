{
  "name": "iso",
  "version": "1.0.0",
  "description": "Full-stack web application to manage an ISO 9001 certification project for ESI.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "build": "npm --prefix frontend run build",
    "seed": "npm --prefix backend run db:seed",
    "db:push": "npm --prefix backend exec prisma db push --skip-generate",
    "test": "echo \"No automated tests configured\"",
    "postinstall": "prisma generate --schema=./backend/prisma/schema.prisma",
    "vercel-build": "prisma generate --schema=./backend/prisma/schema.prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^6.16.2",
    "serverless-http": "^4.0.0",
    "zod": "^4.3.6"
  }
}
